# Nubra SDK credentials (used by InitNubraSdk with env_creds=True)
PHONE_NO=your_phone_number
MPIN=your_mpin

# Environment: uat or production
NUBRA_ENV=uat

# Legacy keys used by auto_otp.py and Rust collector
NUBRA_PHONE=your_phone_number
NUBRA_MPIN=your_mpin
NUBRA_BASE_URL=https://uatapi.nubra.io
NUBRA_WS_URL=wss://uatapi.nubra.io/apibatch/ws

DB_PATH=data.db
MODEL_PATH=nifty_model.pkl
